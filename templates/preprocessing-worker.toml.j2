debug = false
verbosity = 0

[temporal]
address = "127.0.0.1:7233"
namespace = "default"

[worker]
maxConcurrentSessions = 1
taskQueue = "{{ sfa_enduro_worker_task_queue }}"

[preprocessing]
workflowName = "{{ sfa_enduro_worker_preprocessing_workflow_name }}"
sharedPath = "{{ sfa_enduro_worker_preprocessing_shared_path }}"

[preprocessing.bagCreate]
checksumAlgorithm = "md5"

[preprocessing.fileFormat]
allowlistPath = "/etc/allowed_file_formats.csv"

[preprocessing.filevalidate.verapdf]
path = "{{ sfa_enduro_worker_preprocessing_verapdf_path }}"

[poststorage]
workingDir = "/tmp"

[poststorage.apis]
workflowName = "{{ sfa_enduro_worker_poststorage_apis_workflow_name }}"

[poststorage.cantons]
workflowName = "{{ sfa_enduro_worker_poststorage_cantons_workflow_name }}"

[poststorage.cantons.bucket]
url = "{{ sfa_enduro_worker_poststorage_cantons_bucket_url }}"
endpoint = "{{ sfa_enduro_worker_poststorage_cantons_bucket_endpoint }}"
pathStyle = {{ sfa_enduro_worker_poststorage_cantons_bucket_path_style | bool | lower }}
accessKey = "{{ sfa_enduro_worker_poststorage_cantons_bucket_access_key }}"
secretKey = "{{ sfa_enduro_worker_poststorage_cantons_bucket_secret_key }}"
region = "{{ sfa_enduro_worker_poststorage_cantons_bucket_region }}"
bucket = "{{ sfa_enduro_worker_poststorage_cantons_bucket_name }}"

[poststorage.amss]
baseURL = "{{ sfa_enduro_worker_poststorage_amss_base_url }}"
username = "{{ sfa_enduro_worker_poststorage_amss_username }}"
key = "{{ sfa_enduro_worker_poststorage_amss_key }}"

[apis]
enabled = "{{ sfa_enduro_worker_apis_enabled | default('false', true) }}"
url = "{{ sfa_enduro_worker_apis_url }}"
timeout = "{{ sfa_enduro_worker_apis_timeout | default('10s', true) }}"
pollInterval = "{{ sfa_enduro_worker_apis_poll_interval | default('30s', true) }}"
token = "{{ sfa_enduro_worker_apis_token }}"

[apis.oidc]
enabled = "{{ sfa_enduro_worker_apis_oidc_enabled | default('false', true) }}"
providerURL = "{{ sfa_enduro_worker_apis_oidc_provider_url }}"
tokenURL = "{{ sfa_enduro_worker_apis_oidc_token_url }}"
clientID = "{{ sfa_enduro_worker_apis_oidc_client_id }}"
clientSecret = "{{ sfa_enduro_worker_apis_oidc_client_secret }}"
scopes = "{{ sfa_enduro_worker_apis_oidc_scopes }}"
audience = "{{ sfa_enduro_worker_apis_oidc_audience }}"
tokenExpiryLeeway = "{{ sfa_enduro_worker_apis_oidc_token_expiry_leeway | default('30s', true) }}"
retryMaxAttempts = {{ sfa_enduro_worker_apis_oidc_retry_max_attempts | default(3, true) }}
retryInitialInterval = "{{ sfa_enduro_worker_apis_oidc_retry_initial_interval | default('500ms', true) }}"
retryMaxInterval = "{{ sfa_enduro_worker_apis_oidc_retry_max_interval | default('2s', true) }}"
retryBackoffCoefficient = {{ sfa_enduro_worker_apis_oidc_retry_backoff_coefficient | default(2.0, true) }}
