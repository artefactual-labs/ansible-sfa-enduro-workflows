[Unit]
Description=SFA Enduro worker
AssertFileIsExecutable=/usr/bin/sfa-enduro-worker


[Service]
Type=simple
WorkingDirectory={{ sfa_enduro_worker_working_dir }}
User={{ sfa_enduro_worker_system_user }}
Group={{ sfa_enduro_worker_system_group }}
{% if sfa_enduro_worker_systemd_credentials|bool %}
ExecStart=/usr/bin/sfa-enduro-worker --config $SECRETS
{% else %}
ExecStart=/usr/bin/sfa-enduro-worker --config /etc/sfa-enduro-worker.toml
{% endif %}
{% if sfa_enduro_worker_use_syslog|bool %}
SyslogIdentifier=sfa-enduro-worker
StandardOutput=syslog
StandardError=inherit
{% endif %}

# Let systemd restart this service always
#Restart=always

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=1048576

# Specifies the maximum number of threads this process can create
#TasksMax=infinity

# Disable timeout logic and wait until process is stopped
#TimeoutStopSec=infinity
#SendSIGKILL=no

[Install]
WantedBy=multi-user.target
